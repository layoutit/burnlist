{
  "name": "burnlist",
  "version": "0.0.2",
  "type": "module",
  "description": "An agent skill and local dashboard for Burnlist planning, execution, and progress tracking.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "burnlist": "bin/burnlist.mjs"
  },
  "exports": {
    "./differential-testing": "./skills/burnlist/scripts/differential-testing-adapter-sdk.mjs",
    "./differential-testing/contract": "./skills/burnlist/scripts/differential-testing-contract.mjs",
    "./differential-testing/transport": "./skills/burnlist/scripts/differential-testing-transport.mjs"
  },
  "files": [
    "bin/",
    "skills/",
    "skills/burnlist/dashboard/dist/",
    "scripts/register-skills.mjs",
    "scripts/unregister-skills.mjs"
  ],
  "scripts": {
    "build:dashboard": "vite build --config skills/burnlist/dashboard/vite.config.mjs",
    "test:differential-testing": "node --test skills/burnlist/scripts/differential-testing-adapter-sdk.test.mjs skills/burnlist/scripts/differential-testing-contract.test.mjs skills/burnlist/scripts/differential-testing-data-contract.test.mjs skills/burnlist/scripts/differential-testing-transport-renderer.test.mjs skills/burnlist/scripts/differential-testing-transport-server.test.mjs",
    "verify": "node scripts/verify.mjs",
    "verify:clean": "node scripts/verify-clean.mjs",
    "verify:package": "node scripts/verify-package.mjs",
    "test:global-install": "node scripts/smoke-global-install.mjs",
    "prepack": "npm run build:dashboard && npm run verify",
    "postinstall": "node scripts/register-skills.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "radix-ui": "^1.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.1.0"
  }
}
