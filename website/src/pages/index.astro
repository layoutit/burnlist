---
const skillUrl = new URL('/skill.md', Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="A repo-local burndown tracker and read-only observer dashboard for agents." />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Burnlist — a repo-local burndown tracker for agents</title>
    <script>
      try {
        const theme = localStorage.getItem('starlight-theme');
        if (theme === 'light' || theme === 'dark') document.documentElement.dataset.theme = theme;
      } catch {}
    </script>
    <style>
      :root,
      :root[data-theme='dark'] {
        --bg: #000000;
        --panel: #111111;
        --panel-2: #0a0a0a;
        --text: #e8e8e8;
        --muted: #a8a8a8;
        --line: #262626;
        --line-strong: #3a3a3a;
        --accent: #5aa2ff;
        --accent-ink: #050505;
        --accent-soft: rgba(90, 162, 255, 0.14);
        color-scheme: dark;
      }
      :root[data-theme='light'] {
        --bg: #ffffff;
        --panel: #f6f6f6;
        --panel-2: #fafafa;
        --text: #171717;
        --muted: #5b5b5b;
        --line: #e4e4e4;
        --line-strong: #d0d0d0;
        --accent: #2563eb;
        --accent-ink: #ffffff;
        --accent-soft: rgba(37, 99, 235, 0.1);
        color-scheme: light;
      }
      @media (prefers-color-scheme: light) {
        :root:not([data-theme]) {
          --bg: #ffffff; --panel: #f6f6f6; --panel-2: #fafafa; --text: #171717;
          --muted: #5b5b5b; --line: #e4e4e4; --line-strong: #d0d0d0;
          --accent: #2563eb; --accent-ink: #ffffff; --accent-soft: rgba(37, 99, 235, 0.1);
          color-scheme: light;
        }
      }

      :root {
        --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
        --title: 'Helvetica Neue', Helvetica, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        min-width: 320px;
        overflow-x: hidden;
        background: var(--bg);
        color: var(--text);
        font: 400 14.5px/1.6 var(--mono);
      }
      a { color: inherit; text-decoration: none; }
      a:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
      h1, h2, h3 { font-family: var(--title); font-weight: 600; margin: 0; }

      .skip-link {
        position: absolute; left: -9999px; top: 0; z-index: 100;
        background: var(--accent); color: var(--accent-ink);
        font-weight: 600; padding: .6rem 1rem; border-radius: 0 0 8px 0;
      }
      .skip-link:focus { left: 0; }
      .container { width: min(1080px, calc(100% - 40px)); margin-inline: auto; }

      /* Header — the dashboard chrome: black bar, hairline, mono. */
      .topbar { position: sticky; top: 0; z-index: 10; background: var(--bg); border-bottom: 1px solid var(--line); }
      .topbar-inner { min-height: 60px; display: flex; align-items: center; justify-content: space-between; gap: 20px; }
      .brand { display: inline-flex; align-items: center; gap: .5rem; color: var(--text); font-family: var(--mono); font-size: 1rem; font-weight: 700; letter-spacing: -.02em; }
      .brand .logo { color: var(--accent); font-size: 1.35em; line-height: 1; font-weight: 400; }
      .brand b { color: var(--accent); }
      .nav { display: flex; align-items: center; gap: 2px; }
      .nav a { border-radius: 6px; color: var(--muted); font-size: .85rem; padding: .38rem .6rem; white-space: nowrap; }
      .nav a:hover { background: var(--accent-soft); color: var(--text); }

      main { padding: 44px 0 72px; }
      section { margin-top: 72px; scroll-margin-top: 72px; }

      /* Hero — a flat bordered panel like a dashboard card, not a gradient. */
      .hero { margin-top: 0; border: 1px solid var(--line); border-radius: 10px; background: var(--panel-2); padding: clamp(1.8rem, 5vw, 3.4rem); }
      .eyebrow {
        display: inline-flex; align-items: center; gap: .5rem;
        border: 1px solid var(--line); border-radius: 6px; background: var(--panel);
        color: var(--muted); font-family: var(--mono); font-size: .72rem;
        letter-spacing: .03em; padding: .34rem .6rem; text-transform: uppercase;
      }
      .eyebrow::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--accent); }
      h1 { max-width: 16ch; font-size: clamp(2.5rem, 6.5vw, 4.4rem); letter-spacing: -.03em; line-height: 1.02; margin: 1.1rem 0 .7rem; }
      .tagline { color: var(--text); font-family: var(--title); font-weight: 500; font-size: clamp(1.15rem, 2.4vw, 1.55rem); margin-bottom: .8rem; }
      .intro { color: var(--muted); font-size: 1rem; max-width: 68ch; margin: 0; }
      .actions { display: flex; flex-wrap: wrap; gap: .6rem; margin-top: 1.7rem; }
      .button { border: 1px solid var(--line); border-radius: 8px; background: var(--panel); color: var(--text); font-family: var(--mono); font-size: .88rem; font-weight: 600; padding: .58rem .95rem; transition: border-color .15s ease, background .15s ease; }
      .button:hover { border-color: var(--line-strong); background: var(--bg); }
      .button.primary { background: var(--accent); border-color: var(--accent); color: var(--accent-ink); }
      .button.primary:hover { filter: brightness(1.08); background: var(--accent); }

      h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); letter-spacing: -.02em; line-height: 1.15; margin-bottom: .6rem; }
      .section-lede { color: var(--muted); max-width: 66ch; margin: 0; }

      /* Surface cards — dashboard panels. */
      .grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin-top: 1.7rem; }
      @media (min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
      @media (min-width: 1000px) { .grid { grid-template-columns: repeat(3, 1fr); } }
      .card { border: 1px solid var(--line); border-radius: 8px; background: var(--panel); padding: 1.3rem; }
      .card h3 { font-size: 1rem; color: var(--text); margin-bottom: .5rem; }
      .card h3::before { content: '# '; color: var(--accent); font-family: var(--mono); }
      .card p { color: var(--muted); font-size: .875rem; margin: 0; line-height: 1.6; }
      code { font-family: var(--mono); font-size: .88em; color: var(--text); background: var(--accent-soft); border-radius: 4px; padding: .05em .32em; }

      /* Loop panel. */
      .loop { border: 1px solid var(--line); border-radius: 10px; background: var(--panel); padding: clamp(1.3rem, 4vw, 2rem); }
      .steps { list-style: none; padding: 0; display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin: 1.3rem 0; }
      .step { display: inline-flex; align-items: center; gap: 8px; border: 1px solid var(--line); border-radius: 6px; background: var(--panel-2); color: var(--accent); font-family: var(--mono); font-size: .84rem; padding: .32rem .6rem; white-space: nowrap; }
      .step:not(:last-child)::after { content: '→'; color: var(--muted); }
      .loop p { color: var(--muted); max-width: 74ch; margin: 0 0 .8rem; }
      .flow-caption { color: var(--accent) !important; font-family: var(--mono); font-size: .82rem; margin: 0 !important; }

      /* Install. */
      .install-grid { display: grid; grid-template-columns: 1fr; gap: 14px; margin-top: 1.5rem; }
      @media (min-width: 720px) { .install-grid { grid-template-columns: repeat(2, 1fr); } }
      .install-card { border: 1px solid var(--line); border-radius: 10px; background: var(--panel); overflow: hidden; display: flex; flex-direction: column; }
      .install-card h3 { font-size: 1rem; color: var(--text); margin: 0; padding: 1.1rem 1.3rem .85rem; }
      .install-card h3::before { content: '# '; color: var(--accent); font-family: var(--mono); }
      .code-block { position: relative; }
      pre {
        max-width: 100%; overflow-x: auto; margin: 0; background: var(--panel-2);
        border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
        padding: 1.15rem 3rem 1.15rem 1.3rem;
      }
      pre code { color: var(--text); background: transparent; padding: 0; font-size: .92rem; word-break: break-all; }
      .install-copy { padding: 1.1rem 1.3rem; }
      .install-copy p { color: var(--muted); margin: 0; font-size: .875rem; }
      .install-footnote { color: var(--muted); margin-top: 1.2rem; }
      .text-link { color: var(--accent); font-weight: 600; }
      .text-link:hover { text-decoration: underline; text-underline-offset: 3px; }

      /* Copy-to-clipboard icon button — a small square in the code block's corner. */
      .copy-btn {
        position: absolute; top: .5rem; right: .5rem; width: 30px; height: 30px;
        display: inline-flex; align-items: center; justify-content: center;
        border: 1px solid var(--line); border-radius: 6px; background: var(--panel);
        color: var(--muted); cursor: pointer; padding: 0;
        transition: border-color .15s ease, color .15s ease, background .15s ease;
      }
      .copy-btn:hover, .copy-btn:focus-visible { border-color: var(--accent); color: var(--accent); }
      .copy-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
      .copy-btn svg { width: 16px; height: 16px; display: block; }
      .copy-btn .icon-check { display: none; }
      .copy-btn.is-copied { border-color: var(--accent); color: var(--accent); }
      .copy-btn.is-copied .icon-copy { display: none; }
      .copy-btn.is-copied .icon-check { display: block; }

      footer { margin-top: 72px; border-top: 1px solid var(--line); color: var(--muted); font-size: .82rem; padding: 26px 0; }
      .footer-inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 14px; }
      .footer-links { display: flex; gap: 18px; }
      .footer-links a:hover { color: var(--text); }

      @media (max-width: 640px) {
        .topbar-inner { min-height: 54px; }
        .nav a { padding: .34rem .48rem; }
        section { margin-top: 56px; }
      }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        .button { transition: none; }
        .copy-btn { transition: none; }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="topbar">
      <div class="container topbar-inner">
        <a class="brand" href="/" aria-label="Burnlist home"><span class="logo" aria-hidden="true">⟁</span><span class="wordmark"><b>burn</b>list</span></a>
        <nav class="nav" aria-label="Primary navigation">
          <a href="/getting-started">Docs</a>
          <a href="/cli">CLI</a>
          <a href="/ovens">Ovens</a>
          <a href="/dashboard">Dashboard</a>
          <a href="https://github.com/layoutit/burnlist">GitHub</a>
        </nav>
      </div>
    </header>

    <main id="main-content" class="container">
      <section class="hero" aria-labelledby="page-title">
        <span class="eyebrow">Zero runtime dependencies · pure Node · MIT</span>
        <h1 id="page-title">Burnlist</h1>
        <p class="tagline">A repo-local burndown tracker for agents.</p>
        <p class="intro">A shrinking Markdown checklist that renders live progress in a read-only observer dashboard. Burnlist owns task state — not your implementation, tests, or delivery — and never executes your work or drives your agents.</p>
        <div class="actions" aria-label="Get started">
          <a class="button primary" href="/getting-started">Read the docs</a>
          <a class="button" href="#install">Install</a>
          <a class="button" href="https://github.com/layoutit/burnlist">GitHub</a>
        </div>
      </section>

      <section aria-labelledby="surfaces-title">
        <h2 id="surfaces-title">One tracker, five surfaces</h2>
        <p class="section-lede">The same shrinking queue gives agents, repositories, and observers a clear, local view of the work.</p>
        <div class="grid">
          <article class="card"><h3>CLI</h3><p>One command, <code>burnlist</code>, launches the loopback dashboard. Lifecycle verbs (<code>new</code>, <code>ready</code>, <code>start</code>, <code>burn</code>, <code>close</code>) plus protocol helpers (<code>--check</code>, <code>--digest</code>, <code>--stamp</code>) drive the burndown. Run <code>burnlist --help</code> for the full surface.</p></article>
          <article class="card"><h3>Dashboard</h3><p>A read-only web observer. It scans the <code>notes/burnlists/</code> lifecycle folders across your registered repos and refreshes automatically. It never mutates canonical task state.</p></article>
          <article class="card"><h3>Ovens</h3><p>Declarative, non-executable recipes for a Burn: two files — <code>instructions.md</code> (outcome + evidence rules) and <code>&lt;id&gt;.oven</code> (declarative detail-page source). Five built-in Ovens ship: Checklist, Differential Testing, Streaming Diff, Performance Tracing, and Visual Parity.</p></article>
          <article class="card"><h3>Skills</h3><p>A single agent skill owns the full Burnlist lifecycle — creation, hardening, execution, and maintenance — installable for both Claude and Codex, per-repo or global.</p></article>
          <article class="card"><h3>Hooks</h3><p><code>burnlist hooks install --agent codex,claude</code> merges Streaming Diff commands into <code>.codex/hooks.json</code> and <code>.claude/settings.json</code>, preserving your existing hook entries.</p></article>
        </div>
      </section>

      <section aria-labelledby="lifecycle-title">
        <div class="loop">
          <h2 id="lifecycle-title">How burnlist works</h2>
          <ol class="steps" aria-label="Burnlist folder lifecycle">
            <li class="step">draft/</li><li class="step">ready/</li><li class="step">inprogress/</li><li class="step">completed/</li>
          </ol>
          <p>Ready work moves to <code>inprogress</code> before execution and to <code>completed</code> once the active queue is empty. Each active item is validated before it leaves the checklist: the agent appends a terse completion record, deletes the item, then re-checks the Burnlist. <code>burnlist.md</code> is the canonical shrinking queue; <code>goal.md</code> holds the stable contract.</p>
          <p class="flow-caption">new → ready → start → burn → close</p>
        </div>
      </section>

      <section id="install" aria-labelledby="install-title">
        <h2 id="install-title">Install</h2>
        <p class="section-lede">Two ways to get Burnlist running — pick one, or use both.</p>
        <div class="install-grid">
          <div class="install-card">
            <h3>Install globally with npm</h3>
            <div class="code-block">
              <pre><code>npm install --global burnlist</code></pre>
              <button type="button" class="copy-btn" data-copy-text="npm install --global burnlist" aria-label="Copy">
                <svg class="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 19a2 2 0 0 1-1-2V2a2 2 0 0 1 1-1h13a2 2 0 0 1 2 1"></path><rect x="6" y="5" width="16" height="18" rx="1.5" ry="1.5"></rect></svg>
                <svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12.5l4.5 4.5L19 7"></path></svg>
              </button>
            </div>
            <div class="install-copy">
              <p><code>burnlist</code> launches the dashboard from any project.</p>
            </div>
          </div>
          <div class="install-card">
            <h3>Give your agent the skill</h3>
            <div class="code-block">
              <pre><code>{skillUrl}</code></pre>
              <button type="button" class="copy-btn" data-copy-text={skillUrl} aria-label="Copy">
                <svg class="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 19a2 2 0 0 1-1-2V2a2 2 0 0 1 1-1h13a2 2 0 0 1 2 1"></path><rect x="6" y="5" width="16" height="18" rx="1.5" ry="1.5"></rect></svg>
                <svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12.5l4.5 4.5L19 7"></path></svg>
              </button>
            </div>
            <div class="install-copy">
              <p>Paste this URL to your coding agent (Claude Code / Codex) — it fetches a complete, self-contained Burnlist skill. No local setup needed.</p>
            </div>
          </div>
        </div>
        <p class="install-footnote">Requires Node.js 18 or newer. <a class="text-link" href="/getting-started">Read the getting-started guide →</a></p>
      </section>
    </main>

    <footer>
      <div class="container footer-inner">
        <span>Burnlist · MIT License</span>
        <nav class="footer-links" aria-label="Footer navigation">
          <a href="/getting-started">Docs</a>
          <a href="https://github.com/layoutit/burnlist">GitHub</a>
        </nav>
      </div>
    </footer>

    <script>
      document.querySelectorAll('.copy-btn').forEach((button) => {
        const idleAriaLabel = button.getAttribute('aria-label') || 'Copy';
        let resetTimer;
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-copy-text') || '';
          try {
            await navigator.clipboard.writeText(text);
          } catch {
            return;
          }
          window.clearTimeout(resetTimer);
          button.classList.add('is-copied');
          button.setAttribute('aria-label', 'Copied');
          resetTimer = window.setTimeout(() => {
            button.classList.remove('is-copied');
            button.setAttribute('aria-label', idleAriaLabel);
          }, 1500);
        });
      });
    </script>
  </body>
</html>
