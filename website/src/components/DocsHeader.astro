---
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';

const pathname = Astro.url.pathname;
const isLanding = pathname === '/';
const topLinks = [
  { href: '/', label: 'Home' },
  { href: '/getting-started', label: 'Docs' },
  { href: '/cli', label: 'CLI' },
  { href: '/ovens', label: 'Ovens' },
  { href: '/dashboard', label: 'Dashboard' },
];
const isActive = (href: string) =>
  href === '/' ? pathname === href : pathname.startsWith(href);
const siteTitle = config.title ?? 'Burnlist';
---

<header class:list={['header', { 'header--landing': isLanding }]} aria-label={`${siteTitle} navigation`}>
  <div class="header-inner">
    {!isLanding && (
      <a class="brand" href="/" aria-label={`${siteTitle} home`}>
        <SiteTitle />
      </a>
    )}

    <nav class="docs-top-nav" aria-label="Primary navigation">
      {topLinks.map(({ href, label }) => (
        <a href={href} aria-current={isActive(href) ? 'page' : undefined}>{label}</a>
      ))}
    </nav>

    {!isLanding && (
      <div class="header-actions">
        <a
          class="github-pill"
          href="https://github.com/layoutit/burnlist"
          aria-label="View Burnlist on GitHub"
        >
          <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.5c-2.23.49-2.7-.95-2.7-.95-.36-.93-.89-1.18-.89-1.18-.73-.5.06-.49.06-.49.81.06 1.23.83 1.23.83.72 1.23 1.88.88 2.34.67.07-.52.28-.88.51-1.08-1.78-.2-3.65-.89-3.65-3.96 0-.88.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .68-.22 2.2.82A7.68 7.68 0 0 1 8 4.8c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.27.83 2.15 0 3.08-1.87 3.75-3.66 3.95.29.25.54.73.54 1.48v2.2c0 .21.14.46.55.38A8 8 0 0 0 8 0Z" /></svg>
          <span>GitHub</span>
          <span id="star-count-docs" aria-label="GitHub stars"></span>
        </a>
      </div>
    )}
  </div>

  {!isLanding && (
    <div class="sidebar-search-dock">
      <Search />
    </div>
  )}
</header>

<script>
  const starCount = document.getElementById('star-count-docs');
  if (starCount) {
    try {
      const response = await fetch('https://api.github.com/repos/layoutit/burnlist');
      if (response.ok) {
        const repository = await response.json();
        starCount.textContent = String(repository.stargazers_count ?? '');
      }
    } catch {
      // A network failure should not affect navigation.
    }
  }
</script>

<style>
  :global(:root) {
    --sl-nav-height: 72px;
  }

  .header {
    background: var(--sl-color-bg-nav);
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .header-inner {
    display: grid;
    grid-template-columns: minmax(10rem, 1fr) auto minmax(10rem, 1fr);
    align-items: center;
    gap: 1rem;
    width: min(100%, 90rem);
    height: var(--sl-nav-height);
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .brand {
    color: var(--sl-color-text);
    font-family: var(--sl-font-mono);
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
  }

  .docs-top-nav {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .docs-top-nav a {
    color: var(--sl-color-gray-2);
    border-radius: 0.45rem;
    padding: 0.45rem 0.65rem;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .docs-top-nav a:hover,
  .docs-top-nav a[aria-current='page'] {
    color: var(--sl-color-text);
    background: rgba(56, 189, 248, 0.14);
  }

  .header-actions {
    justify-self: end;
  }

  .github-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.65rem;
    color: #24292f;
    background: #f6f8fa;
    border: 1px solid #d0d7de;
    border-radius: 0.45rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
  }

  .github-pill svg {
    width: 1rem;
    fill: currentColor;
  }

  .github-pill #star-count-docs:empty {
    display: none;
  }

  .github-pill #star-count-docs::before {
    content: '★';
    margin-right: 0.2rem;
  }

  .header--landing .header-inner {
    grid-template-columns: 1fr;
  }

  .header--landing .docs-top-nav:only-child {
    grid-column: 1 / -1;
    justify-content: center;
  }

  .sidebar-search-dock {
    display: none;
  }

  @media (max-width: 38rem) {
    .header-inner {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      height: auto;
      min-height: var(--sl-nav-height);
      padding: 0.55rem 1rem;
    }

    .docs-top-nav {
      grid-column: 1 / -1;
      grid-row: 2;
      width: 100%;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .docs-top-nav::-webkit-scrollbar {
      display: none;
    }

    .header--landing .header-inner {
      display: flex;
      min-height: var(--sl-nav-height);
    }

    .header--landing .docs-top-nav {
      justify-content: flex-start;
    }
  }
</style>
